# Node identity
NODE_NAME="US-1"
NODE_ROLE="foreign" # foreign or ru
SERVER_HOST="CHANGE_ME_PUBLIC_IP_OR_DOMAIN"

# REALITY camouflage target. Pick a real HTTPS site with TLS 1.3/H2 and no redirect.
REALITY_DEST="www.microsoft.com:443"
REALITY_SNI="www.microsoft.com"

# First client generated during install
CLIENT_NAME="serg-phone"

# Network
XRAY_PORT="443"
SSH_PORT="22"

# Optional: block BitTorrent traffic on the server side
BLOCK_BITTORRENT="yes"

# Logging: none|minimal
LOG_LEVEL="warning"

# Optional SSH hardening settings for scripts/install-hardening.sh
# HARDENING_USER="serg"
# HARDENING_PUBLIC_KEY="ssh-ed25519 AAAA... your-key-comment"
# DISABLE_PASSWORD_AUTH="yes"
# DISABLE_ROOT_LOGIN="no" # change to yes only after verifying sudo-user key login
# ENABLE_UFW="yes"
# INSTALL_FAIL2BAN="yes"
